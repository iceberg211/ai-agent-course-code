NODE_ENV=development
PORT=3001

# Supabase
# 连接池（应用运行时，TypeORM 使用）
# 从 Dashboard → Settings → Database → Connection pooling 复制
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-1-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
# TypeORM SQL 日志（调试时开启）
TYPEORM_LOGGING=false
# 直连（supabase db push 时使用，应用不用这个）
# 从 Dashboard → Settings → Database → Direct connection 复制
DIRECT_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-1-[REGION].pooler.supabase.com:5432/postgres
# 从 Dashboard → Settings → API → Project URL 复制
SUPABASE_URL=https://[PROJECT-REF].supabase.co
# 从 Dashboard → Settings → API → service_role 复制
SUPABASE_SERVICE_ROLE_KEY=

# 千问 / DashScope（LLM + Embeddings）
# 注册：https://dashscope.aliyuncs.com
OPENAI_API_KEY=
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_API_KEY=
MODEL_NAME=qwen-plus
EMBEDDINGS_MODEL_NAME=text-embedding-v3

# LangSmith（可选，开发期 RAG 链路观测）
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=digital-human-agent-rag

# Query Rewrite（可选，默认关闭以保持现有回答行为）
QUERY_REWRITE_ENABLED=false
QUERY_REWRITE_MODEL_NAME=qwen-plus

# ASR（DashScope Paraformer）
ASR_MODEL=paraformer-realtime-v2

# TTS / 语音克隆（DashScope CosyVoice）
TTS_MODEL=cosyvoice-v3.5-plus
TTS_DEFAULT_VOICE=longxiaochun

# 数字人（Simli）
# 注册：https://simli.ai
# 获取可用 faceId：GET https://api.simli.ai/getPossibleFaceIDs (带 x-simli-key 请求头)
DIGITAL_HUMAN_PROVIDER=mock
SIMLI_API_KEY=
SIMLI_FACE_ID=
SIMLI_BASE_URL=https://api.simli.ai
