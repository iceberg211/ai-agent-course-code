NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173
WS_ALLOWED_ORIGINS=http://localhost:5173
# 生产环境必须配置。开发环境留空时仅依赖 CORS 约束。
WS_AUTH_TOKEN=
# 生产环境必须配置。逗号分隔，写接口通过 x-api-key 传入。
APP_API_KEYS=

# ─── 数据库（Supabase PostgreSQL）─────────────────────────────────────────────
# 运行时连接（pgBouncer 连接池，port 6543）
DATABASE_URL="postgresql://username:password@host:6543/postgres?pgbouncer=true"
# 直连（用于 migration，port 5432）
DIRECT_URL="postgresql://username:password@host:5432/postgres"

# ─── LLM（OpenAI 兼容接口）────────────────────────────────────────────────────
OPENAI_API_KEY="your-api-key"
# 使用 OpenAI 原生接口时留空或填 https://api.openai.com/v1
OPENAI_BASE_URL="https://api.openai.com/v1"
MODEL_NAME="gpt-4o-mini"
EMBEDDINGS_MODEL_NAME="text-embedding-3-small"

# ─── 工具 API Keys ─────────────────────────────────────────────────────────────
TAVILY_API_KEY="your-tavily-api-key"
# GitHub 可选，不填则使用未认证 API（有速率限制）
GITHUB_TOKEN=""

# ─── Workspace ─────────────────────────────────────────────────────────────────
WORKSPACE_BASE_DIR="/tmp/mini-manus-workspaces"

# ─── Agent 行为参数 ────────────────────────────────────────────────────────────
MAX_RETRIES=3
MAX_REPLANS=2
MAX_STEPS=20
TOKEN_BUDGET=100000
PLANNER_MAX_STEPS=20
PLANNER_ALLOWED_SIDE_EFFECT_TOOLS=write_file,download_file,export_pdf,browser_screenshot
PLANNER_ALLOWED_SIDE_EFFECT_SKILLS=document_writing,report_packaging,code_project_generation
STEP_TIMEOUT_MS=60000
# Skill 超时单独配置（skill 内含多次网络+LLM 调用，需要更长时间）
SKILL_TIMEOUT_MS=300000
APPROVAL_TIMEOUT_MS=600000

# ─── Workspace 清理 ───────────────────────────────────────────────────────────
WORKSPACE_CLEANUP_ENABLED=false
WORKSPACE_RETENTION_DAYS=7
WORKSPACE_CLEANUP_INTERVAL_MS=21600000

# ─── 只读浏览器自动化 ─────────────────────────────────────────────────────────
# 启用后 ToolRegistry 会注册 browser_open / browser_extract / browser_screenshot
BROWSER_AUTOMATION_ENABLED=false
BROWSER_HEADLESS=true
BROWSER_MAX_SESSIONS_PER_RUN=2
BROWSER_DEFAULT_TIMEOUT_MS=15000
BROWSER_ACTION_TIMEOUT_MS=10000
BROWSER_SESSION_TTL_MS=600000

# ─── 缓存 ──────────────────────────────────────────────────────────────────────
TOOL_CACHE_TTL_MS=300000
LLM_CACHE_ENABLED=true

# ─── 结构化输出方式 ────────────────────────────────────────────────────────────
# functionCalling  通用，兼容 Qwen / Ollama / Azure（推荐）
# json_schema      OpenAI 原生，仅 gpt-4o 支持完整
# jsonMode         最宽松，适合不支持函数调用的模型
STRUCTURED_OUTPUT_METHOD=functionCalling

# ─── 产物导出 ──────────────────────────────────────────────────────────────────
# 注意：当前 PDF 导出不支持中文，建议保持 false
EXPORT_PDF_ENABLED=false

# ─── LangSmith 链路追踪（可选）────────────────────────────────────────────────
# 注册：https://smith.langchain.com
# 留空 LANGCHAIN_API_KEY 则不启用
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=mini-manus
